# Full API base URL (optional). If set, the Vite dev proxy below is NOT used for API calls.
# Example: http://localhost:5000/api
# VITE_API_URL=

# If your backend runs on a port other than 5000, set this so Vite can proxy /api correctly.
# Example: http://127.0.0.1:4000
# VITE_DEV_API_ORIGIN=http://127.0.0.1:5000

# Optional: Socket.io origin if different from the page (defaults to same origin in dev via Vite proxy).
# VITE_SOCKET_URL=http://127.0.0.1:5000
